---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/philosophy', label: 'Philosophy' },
  { href: '/art', label: 'Art' },
  { href: '/music', label: 'Music' },
  { href: '/games', label: 'Games' },
  { href: '/anime', label: 'Anime' },
  { href: '/animations', label: 'Animations' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg-dark/90 backdrop-blur-md border-b border-primary">
  <div class="max-w-7xl mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <a href="/" class="font-heading text-2xl font-bold text-text-primary hover:text-accent transition-colors duration-300">
        IMH
      </a>
      <div class="hidden md:flex items-center gap-8">
        {navItems.map((item) => (
          <a 
            href={item.href}
            class="font-body text-sm text-text-secondary hover:text-text-primary hover:text-accent transition-all duration-300 relative group"
          >
            {item.label}
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-accent transition-all duration-300 group-hover:w-full"></span>
          </a>
        ))}
      </div>
      <button id="mobile-menu-btn" class="md:hidden text-text-primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  <div id="mobile-menu" class="hidden md:hidden bg-bg-dark/95 backdrop-blur-md border-t border-primary">
    <div class="px-6 py-4 flex flex-col gap-4">
      {navItems.map((item) => (
        <a 
          href={item.href}
          class="font-body text-text-secondary hover:text-text-primary hover:text-accent transition-colors duration-300"
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
